# ============================================
# CONFIGURAÇÃO EVOLUTION API
# ============================================
# Este arquivo deve ser renomeado para .env
# e colocado no mesmo diretório do docker-compose.yml

# SERVIDOR
SERVER_PORT=8080
SERVER_URL=http://localhost:8081

# BANCO DE DADOS - SUPABASE
# Usando Supabase ao invés de banco local
# IMPORTANTE: Use o Connection Pooler (porta 6543) para conexões externas
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
# Opção 1: Connection Pooler (RECOMENDADO - funciona de qualquer lugar)
# Connection string correta do Supabase Connection Pooler
# IMPORTANTE: Sempre adicione ?schema=evolution_api no final!
DATABASE_CONNECTION_URI=postgresql://postgres.bukigyhhgrtgryklabjg:Joao123.@&*(@aws-1-us-east-2.pooler.supabase.com:6543/postgres?schema=evolution_api

# Opção 2: Direct Connection (só funciona se IP estiver na whitelist do Supabase)
# Para usar esta opção, você precisa adicionar o IP do servidor na whitelist do Supabase
# Settings → Database → Connection Pooling → IPv4 addresses → Add IPv4 address
# DATABASE_CONNECTION_URI=postgresql://postgres:SUA_SENHA_AQUI@db.bukigyhhgrtgryklabjg.supabase.co:5432/postgres?schema=evolution_api

# REDIS
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379

# AUTENTICAÇÃO
AUTHENTICATION_API_KEY=261387f8444ef4334c3fc994cf7bde037e9319c0accf0e31deee705b20b80628

# IDIOMA
LANGUAGE=pt-BR

# WEBSOCKET
WEBSOCKET_ENABLED=true
WEBSOCKET_GLOBAL_EVENTS=true

# CORS (ajuste para seu domínio)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_METHODS=POST,GET,PUT,DELETE
CORS_CREDENTIALS=true

# ============================================
# NOTA SOBRE NOME DA INSTÂNCIA
# ============================================
# O nome da instância (ZkOficial) NÃO precisa estar aqui!
# Ele é criado via API ou Manager depois que o Docker está rodando.
# 
# Para criar a instância:
# 1. Acesse o Manager: http://localhost:3001
# 2. Ou use a API: POST /instance/create com { "instanceName": "ZkOficial" }

